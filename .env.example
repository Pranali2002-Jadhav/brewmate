# BrewMate Environment Variables
# Copy this to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here-minimum-50-characters-random
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (for production — leave blank for SQLite in dev)
DATABASE_URL=postgres://user:password@host:5432/brewmate_db

# Redis (optional — for caching and rate limiting in production)
REDIS_URL=redis://127.0.0.1:6379/1

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS S3 for media (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
